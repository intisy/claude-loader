{
  "name": "claude-code-loader",
  "version": "1.1.2",
  "description": "TUI launcher and cc shell command for Claude Code.",
  "main": "dist/plugin.js",
  "type": "module",
  "license": "MIT",
  "author": "intisy",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/intisy/claude-code-loader.git"
  },
  "keywords": [
    "claude",
    "claude-code",
    "plugin",
    "launcher",
    "tui"
  ],
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "claudeHub": {
    "daemon": {
      "script": "core/dist/proxy.js",
      "runtime": "bun",
      "port": 34567,
      "healthCheckUrl": "http://127.0.0.1:34567/health"
    }
  },
  "scripts": {
    "build": "npx tsc --project core/tsconfig.json && npx tsc",
    "prepublishOnly": "npm run build",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "plugin-updater": "^1.0.21",
    "typescript": "^6.0.3"
  }
}
